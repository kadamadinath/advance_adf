{
	"name": "data_ingestion",
	"properties": {
		"activities": [
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.cities",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "WebforWeather",
							"type": "WebActivity",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"method": "GET",
								"url": {
									"value": "@concat(\n  'https://api.open-meteo.com/v1/forecast?latitude=',\n  item().lat,\n  '&longitude=',\n  item().lon,\n  '&current_weather=true'\n)",
									"type": "Expression"
								}
							}
						},
						{
							"name": "CopyWeatherData",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "RestSource",
									"additionalColumns": [
										{
											"value": "$$COLUMN:"
										}
									],
									"httpRequestTimeout": "00:01:40",
									"requestInterval": "00.00:00:00.010",
									"requestMethod": "GET",
									"paginationRules": {
										"supportRFC5988": "true"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
									}
								},
								"enableStaging": false
							},
							"inputs": [
								{
									"referenceName": "ds_source_API",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_sink_adls",
									"type": "DatasetReference"
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"cities": {
				"type": "array",
				"defaultValue": [
					{
						"city": "Pune",
						"lat": 18.52,
						"lon": 73.85
					},
					{
						"city": "Mumbai",
						"lat": 19.07,
						"lon": 72.87
					},
					{
						"city": "Delhi",
						"lat": 28.61,
						"lon": 77.2
					},
					{
						"city": "Bangalore",
						"lat": 12.97,
						"lon": 77.59
					}
				]
			}
		},
		"annotations": []
	}
}